# Ghost Pay AWS — Environment Variables
# ======================================
# Copy this file to .env for local development.
# In production, secrets are stored in AWS Secrets Manager
# and table/bucket names are injected by the SAM template.

# AWS (auto-injected by Lambda runtime)
AWS_REGION=us-east-1

# DynamoDB table names (set by SAM template in production)
TRANSACTIONS_TABLE=GhostPayTransactions
MERCHANTS_TABLE=GhostPayMerchants
IDEMPOTENCY_TABLE=GhostPayIdempotency

# S3 (set by SAM template in production)
AUDIO_BUCKET=ghost-pay-audio

# Kora (non-secret — set as Lambda env var)
KORA_WEBHOOK_URL=https://{api-id}.execute-api.us-east-1.amazonaws.com/koraWebhook
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# Firebase/GCP project (for FCM push notifications)
FIREBASE_PROJECT_ID=ghost-pay-kora-hackathon

# Secrets Manager secret names (NOT raw keys)
OPENAI_SECRET_NAME=ghostpay/openai
GEMINI_SECRET_NAME=ghostpay/gemini
YARNGPT_SECRET_NAME=ghostpay/yarngpt
KORA_SECRET_NAME=ghostpay/kora
WHATSAPP_SECRET_NAME=ghostpay/whatsapp
JWT_SECRET_NAME=ghostpay/jwt
GOOGLE_SA_SECRET_NAME=ghostpay/google-sa
